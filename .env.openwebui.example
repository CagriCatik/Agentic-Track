# Copy to .env.openwebui and adjust if needed.
# Open WebUI host port (open http://localhost:3000 by default)
OPEN_WEBUI_PORT=3000

# RAG API host port (OpenAI-compatible bridge endpoint)
RAG_API_PORT=8001

# Local Ollama endpoint from inside Docker Desktop container network
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Set to True if you want login/auth enabled
WEBUI_AUTH=False

# Open WebUI -> OpenAI-compatible endpoint routing (to rag-api service)
ENABLE_OPENAI_API=True
OPENAI_API_BASE_URL=http://rag-api:8001/v1
OPENAI_API_KEY=agentic-track-local
OPENAI_API_BASE_URLS=http://rag-api:8001/v1
OPENAI_API_KEYS=agentic-track-local

# Preferred default model visible in Open WebUI
DEFAULT_MODELS=agentic-rag

# RAG API model identity + auth
RAG_API_MODEL_ID=agentic-rag
RAG_API_KEY=agentic-track-local

# LangSmith tracing (rag-api)
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=agentic-track-rag
LANGSMITH_API_KEY=

# Optional hard-pin of underlying Ollama models (leave empty for auto-detect)
RAG_CHAT_MODEL=
RAG_EMBED_MODEL=

# Corpus + vector DB settings
RAG_CORPUS_DIR=/app/corbus
RAG_VECTOR_DB_DIR=/app/data/chroma
RAG_COLLECTION_NAME=agentic_rag_docs
RAG_RETRIEVAL_CANDIDATES=12
RAG_RERANKER_ENABLED=True
RAG_RERANKER_MODE=auto
RAG_RERANKER_MODEL=
RAG_RERANKER_TOP_N=8
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
RAG_INDEX_ON_START=False
RAG_REINDEX_ON_START=False
